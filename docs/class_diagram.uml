@startuml
class partida {
    ID: int
    Time1: *time
    Time2: *time
    GolsTime1: int
    GolsTime2: int
}
class time{
    ID: int
    Nome: char[]
}
partida "n" -- "2" time
class bdpartida{
    partidas: partidas[90]
    bdpartida_busca_return busca(nome_prex: char[])
    void listagem()
}
class bdtime{
    times: time[10]
    bdtime_busca_return busca(nome_prex: char[])
    void listagem()
}
class bdtime_busca_return{
    time: **time
    quant: int
}
class bdpartida_busca_return{
    partid: **partida
    quant: int
}
bdpartida "n" -- "1" partida
bdtime "n" -- "1" time
@enduml